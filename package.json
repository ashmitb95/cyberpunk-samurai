{
  "name": "cyberpunk-samurai",
  "displayName": "Cyberpunk Samurai",
  "description": "Five dark Cyberpunk/Night City themes — Arasaka, Samurai, Japantown — built on One Dark comfort with neon accents.",
  "version": "0.1.0",
  "publisher": "SingularityInc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashmitb95/cyberpunk-samurai"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "cyberpunk",
    "neon",
    "dark",
    "theme",
    "synthwave",
    "night city",
    "arasaka",
    "samurai",
    "japantown"
  ],
  "galleryBanner": {
    "color": "#090d14",
    "theme": "dark"
  },
  "icon": "assets/icon.png",
  "scripts": {
    "build": "node src/build.mjs",
    "icon": "node scripts/render-icon.mjs",
    "test": "node --test"
  },
  "contributes": {
    "themes": [
      {
        "label": "Cyberpunk Samurai: Arasaka Corpo",
        "uiTheme": "vs-dark",
        "path": "./themes/arasaka-corpo.json"
      },
      {
        "label": "Cyberpunk Samurai: Samurai",
        "uiTheme": "vs-dark",
        "path": "./themes/samurai.json"
      },
      {
        "label": "Cyberpunk Samurai: Arasaka Dim",
        "uiTheme": "vs-dark",
        "path": "./themes/arasaka-dim.json"
      },
      {
        "label": "Cyberpunk Samurai: Samurai Dim",
        "uiTheme": "vs-dark",
        "path": "./themes/samurai-dim.json"
      },
      {
        "label": "Cyberpunk Samurai: Japantown",
        "uiTheme": "vs-dark",
        "path": "./themes/japantown.json"
      }
    ]
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
