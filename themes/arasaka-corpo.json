  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4a5568",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f63a4c"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#e3eaf2"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6f9fd8"
      }
    },
    {
      "name": "Class/Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#88c0d0"
      }
    },
    {
      "name": "This/Property",
      "scope": [
        "variable.language.this",
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#f63a4c"
      }
    },
    {
      "name": "Number/Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#cdb88a"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e3eaf2"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#f63a4c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#f63a4c"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5c66"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#88c0d0",
    "class": "#88c0d0",
    "type": "#88c0d0",
    "struct": "#88c0d0",
    "enum": "#88c0d0",
    "interface": "#88c0d0",
    "function": "#6f9fd8",
    "method": "#6f9fd8",
    "macro": "#6f9fd8",
    "variable": "#e3eaf2",
    "parameter": "#e3eaf2",
    "property": "#f63a4c",
    "enumMember": "#cdb88a",
    "keyword": "#f63a4c",
    "string": "#56b6c2",
    "number": "#cdb88a",
    "comment": {
      "foreground": "#4a5568",
      "fontStyle": "italic"
    }
  }
}
