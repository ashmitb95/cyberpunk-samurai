  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#736f50",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#fcee0a"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#e8e4cb"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#c8e64b"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#00d7f2"
      }
    },
    {
      "name": "Class/Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ff5cae"
      }
    },
    {
      "name": "This/Property",
      "scope": [
        "variable.language.this",
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#ff3864"
      }
    },
    {
      "name": "Number/Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ff3864"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e8e4cb"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#fcee0a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#c8e64b"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#fcee0a"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5c66"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ff5cae",
    "class": "#ff5cae",
    "type": "#ff5cae",
    "struct": "#ff5cae",
    "enum": "#ff5cae",
    "interface": "#ff5cae",
    "function": "#00d7f2",
    "method": "#00d7f2",
    "macro": "#00d7f2",
    "variable": "#e8e4cb",
    "parameter": "#e8e4cb",
    "property": "#ff3864",
    "enumMember": "#ff3864",
    "keyword": "#fcee0a",
    "string": "#c8e64b",
    "number": "#ff3864",
    "comment": {
      "foreground": "#736f50",
      "fontStyle": "italic"
    }
  }
}
