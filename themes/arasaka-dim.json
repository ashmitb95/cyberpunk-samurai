  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4a5568",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d86575"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#c2ccd6"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5aa6b0"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6e96c4"
      }
    },
    {
      "name": "Class/Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#82b3c0"
      }
    },
    {
      "name": "This/Property",
      "scope": [
        "variable.language.this",
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#d86575"
      }
    },
    {
      "name": "Number/Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#c0ac84"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c2ccd6"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d86575",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#5aa6b0"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#d86575"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5c66"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#82b3c0",
    "class": "#82b3c0",
    "type": "#82b3c0",
    "struct": "#82b3c0",
    "enum": "#82b3c0",
    "interface": "#82b3c0",
    "function": "#6e96c4",
    "method": "#6e96c4",
    "macro": "#6e96c4",
    "variable": "#c2ccd6",
    "parameter": "#c2ccd6",
    "property": "#d86575",
    "enumMember": "#c0ac84",
    "keyword": "#d86575",
    "string": "#5aa6b0",
    "number": "#c0ac84",
    "comment": {
      "foreground": "#4a5568",
      "fontStyle": "italic"
    }
  }
}
