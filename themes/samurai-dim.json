  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#635f47",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d6c93a"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#cfccb4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a8c050"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4eaebd"
      }
    },
    {
      "name": "Class/Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#d97aa6"
      }
    },
    {
      "name": "This/Property",
      "scope": [
        "variable.language.this",
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#d95f7a"
      }
    },
    {
      "name": "Number/Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d95f7a"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#cfccb4"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#d6c93a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#a8c050"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#d6c93a"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5c66"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#d97aa6",
    "class": "#d97aa6",
    "type": "#d97aa6",
    "struct": "#d97aa6",
    "enum": "#d97aa6",
    "interface": "#d97aa6",
    "function": "#4eaebd",
    "method": "#4eaebd",
    "macro": "#4eaebd",
    "variable": "#cfccb4",
    "parameter": "#cfccb4",
    "property": "#d95f7a",
    "enumMember": "#d95f7a",
    "keyword": "#d6c93a",
    "string": "#a8c050",
    "number": "#d95f7a",
    "comment": {
      "foreground": "#635f47",
      "fontStyle": "italic"
    }
  }
}
